# =========================================================
# Photography portfolio — environment variables
# Copy to `.env` for local function testing (netlify dev) and set the
# same keys in Netlify → Site settings → Environment variables for prod.
# Do NOT commit real values. Only production (cloud) mode needs these;
# the default LOCAL mode needs none of them.
# =========================================================

# --- Owner identity (server-side source of truth) ---
# The Netlify functions grant write access ONLY when the verified
# Google ID token's email exactly matches this value.
ADMIN_EMAIL=vikashsri987@gmail.com

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# --- Google OAuth (Google Identity Services) ---
# The client id is public (also put it in photography/config.js →
# googleClientId to enable the Sign-in button). The functions use it as
# the required token audience. The secret is only needed if you later
# add a server-side OAuth code exchange; GIS ID-token sign-in does not
# require it on the client.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# --- Database (Supabase / Postgres) ---
DATABASE_URL=postgres://user:password@host:5432/dbname
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# SECRET — server only. Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Image storage (Cloudinary) ---
# CLOUDINARY_API_SECRET is SECRET — server only. Used by
# netlify/functions/_cloudinary.js to sign direct-upload requests and to
# delete assets. NEVER exposed to the browser, logs, or Git — the browser
# only ever receives a short-lived signature (see cloudinary-signature.js).
# CLOUDINARY_CLOUD_NAME is NOT secret (it's part of every public delivery
# URL) — also set as photography/config.js → cloudinaryCloudName.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Root folder for all uploads from this app, e.g. "vikash-gallery".
CLOUDINARY_UPLOAD_FOLDER=vikash-gallery

# --- Session/signing secret (if you add server sessions later) ---
AUTH_SECRET=generate-a-long-random-string
